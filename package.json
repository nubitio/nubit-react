{
  "name": "nubit-react",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsdown && node scripts/bundle-nubit-css.mjs && pnpm build:themes",
    "build:themes": "sass packages/ui/theme/styles/theme-dark.scss packages/ui/dist/themes/nb-theme-dark.css --no-source-map && sass packages/ui/theme/styles/theme-light.scss packages/ui/dist/themes/nb-theme-light.css --no-source-map",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages examples",
    "format": "prettier --write \"**/*.{ts,tsx,json,scss,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,json,scss,md}\"",
    "validate:packages": "node scripts/validate-packages.mjs",
    "version:set": "node scripts/set-version.mjs",
    "example:build": "pnpm --filter admin-demo build",
    "example:dev": "pnpm --filter admin-demo dev",
    "example:e2e": "pnpm --filter admin-demo test:e2e",
    "eject": "node packages/eject/bin/nubit.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@eslint/js": "^9.39.0",
    "@tanstack/react-query": "^5.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@tsdown/css": "^0.22.0",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/react": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@types/node": "^22.19.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.39.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "happy-dom": "^20.9.0",
    "i18next": "^23.16.8",
    "prettier": "^3.8.1",
    "publint": "^0.3.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
    "react-i18next": "^14.1.3",
    "react-router-dom": "^6.30.3",
    "sass": "^1.97.3",
    "tsdown": "^0.22.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.1.7"
  },
  "dependencies": {}
}
