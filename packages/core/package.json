{
  "name": "@nubitio/core",
  "version": "0.5.28",
  "type": "module",
  "description": "Runtime foundation for Nubit: HTTP client, event bus, i18n, Mercure SSE, CoreProvider, and date utilities.",
  "license": "MIT",
  "keywords": [
    "react",
    "admin",
    "http",
    "mercure",
    "i18n",
    "event-bus"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nubitio/nubit-react.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/nubitio/nubit-react/issues"
  },
  "homepage": "https://github.com/nubitio/nubit-react/tree/main/packages/core#readme",
  "source": "./public.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "i18next": "^23.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^14.0.0"
  }
}
