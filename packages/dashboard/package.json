{
  "name": "@nubitio/dashboard",
  "version": "0.7.4",
  "type": "module",
  "description": "Declarative dashboard engine with stat cards, charts, and data tables for Nubit admin apps.",
  "license": "MIT",
  "keywords": [
    "react",
    "admin",
    "dashboard",
    "analytics",
    "charts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nubitio/nubit-react.git",
    "directory": "packages/dashboard"
  },
  "bugs": {
    "url": "https://github.com/nubitio/nubit-react/issues"
  },
  "homepage": "https://github.com/nubitio/nubit-react/tree/main/packages/dashboard#readme",
  "source": "./public.ts",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./style.css": "./dist/style.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@nubitio/core": "workspace:^",
    "@nubitio/ui": "workspace:^",
    "@tanstack/react-query": "^5.0.0",
    "react": "^18.2.0 || ^19.0.0",
    "react-dom": "^18.2.0 || ^19.0.0",
    "react-router-dom": "^6.0.0",
    "recharts": "^3.0.0"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.0.0",
    "recharts": "^3.9.2"
  }
}
