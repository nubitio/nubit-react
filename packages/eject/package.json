{
  "name": "@nubitio/eject",
  "version": "0.8.2",
  "description": "Eject explicit resource definitions from Hydra API docs",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "nubit",
    "hydra",
    "api-platform",
    "codegen",
    "cli"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nubitio/nubit-react.git",
    "directory": "packages/eject"
  },
  "bugs": {
    "url": "https://github.com/nubitio/nubit-react/issues"
  },
  "homepage": "https://github.com/nubitio/nubit-react/tree/main/packages/eject#readme",
  "bin": {
    "nubit": "./bin/nubit.mjs"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": {
        "import": "./dist/index.d.mts",
        "require": "./dist/index.d.cts"
      },
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "bin"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "dependencies": {
    "@nubitio/crud": "workspace:*",
    "@nubitio/hydra": "workspace:*"
  }
}
